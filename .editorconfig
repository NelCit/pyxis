# Pyxis editor config — keep IDE / editor formatting consistent with the
# checked-in clang-format and the platform tooling.
root = true

[*]
charset = utf-8
indent_style = space
indent_size = 2
trim_trailing_whitespace = true
insert_final_newline = true
end_of_line = lf

[*.{ps1,cmd,bat}]
end_of_line = crlf

[Makefile]
indent_style = tab
