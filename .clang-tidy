# Pyxis clang-tidy — plan §36.2.
#
# WarningsAsErrors '*' makes any new diagnostic block a PR. Curated check set
# matches §30 (coding rules), §30.11 (Flecs convention), and the explicit
# §36.2 list.
#
# Two clang-analyzer checks are explicitly disabled because they're
# fundamentally incompatible with Pyxis idioms / third-party deps:
#
#   * `optin.core.EnumCastOutOfRange` — Pyxis's strong-handle pattern
#     (§19.7) is `enum class : uint32_t` with only `Invalid = 0` named.
#     Every cast of a packed (slot, generation) uint to the enum is
#     flagged "not in the valid range". The cast IS the protocol;
#     suppressing the check is correct here. (NVRHI also trips it on
#     `AccelStructBuildFlags` because bitset enums combine values.)
#
#   * `optin.cplusplus.UninitializedObject` — NVRHI's BindingSetItem
#     default ctor leaves 8 fields uninitialized (they're set via
#     factory functions like ::Texture_SRV / ::StructuredBuffer_UAV).
#     Inter-procedural analysis from our call sites flags this every
#     time we touch a BindingSetItem. Third-party API contract; not
#     something Pyxis can fix.
#
# Both fire only in Release (CI) clang-tidy runs; the Debug local
# build doesn't trigger inter-procedural analysis the same way, so
# the local Debug build hides these false positives. The PR-blocking
# CI build does.

Checks: >
  bugprone-*,
  -bugprone-easily-swappable-parameters,
  -bugprone-invalid-enum-default-initialization,
  -bugprone-narrowing-conversions,
  performance-*,
  -performance-enum-size,
  modernize-use-nullptr,
  modernize-use-override,
  modernize-use-default-member-init,
  modernize-use-using,
  modernize-make-unique,
  modernize-use-noexcept,
  cppcoreguidelines-pro-type-cstyle-cast,
  cppcoreguidelines-pro-type-member-init,
  cppcoreguidelines-slicing,
  hicpp-exception-baseclass,
  misc-const-correctness,
  misc-unused-parameters,
  readability-identifier-naming,
  readability-identifier-length,
  -clang-analyzer-optin.core.EnumCastOutOfRange,
  -clang-analyzer-optin.cplusplus.UninitializedObject

WarningsAsErrors: '*'
HeaderFilterRegex: 'sources/pyxis_.*'

CheckOptions:
  # Naming (§30.2).  Note: PascalCase is encoded as "CamelCase" in clang-tidy.
  readability-identifier-naming.ClassCase:                 CamelCase
  readability-identifier-naming.StructCase:                CamelCase
  readability-identifier-naming.EnumCase:                  CamelCase
  readability-identifier-naming.UnionCase:                 CamelCase
  readability-identifier-naming.TypedefCase:               CamelCase
  readability-identifier-naming.TypeAliasCase:             CamelCase

  readability-identifier-naming.FunctionCase:              CamelCase
  readability-identifier-naming.MethodCase:                CamelCase

  readability-identifier-naming.LocalVariableCase:         camelBack
  readability-identifier-naming.ParameterCase:             camelBack
  readability-identifier-naming.PublicMemberCase:          camelBack

  readability-identifier-naming.PrivateMemberPrefix:       '_'
  readability-identifier-naming.PrivateMemberCase:         camelBack
  readability-identifier-naming.ProtectedMemberPrefix:     '_'
  readability-identifier-naming.ProtectedMemberCase:       camelBack

  # Compile-time constants share the macro casing (UPPER_CASE, no prefix
  # — macros keep their PYXIS_ prefix). House preference; the §30.2 row
  # has been updated in lockstep.
  readability-identifier-naming.GlobalConstantCase:        UPPER_CASE
  readability-identifier-naming.ConstexprVariableCase:     UPPER_CASE
  readability-identifier-naming.StaticConstantCase:        UPPER_CASE
  readability-identifier-naming.ClassConstantCase:         UPPER_CASE

  readability-identifier-naming.NamespaceCase:             lower_case

  readability-identifier-naming.MacroDefinitionCase:       UPPER_CASE
  readability-identifier-naming.MacroDefinitionPrefix:     'PYXIS_'

  # Enum constants are plain CamelCase (no prefix) — house preference.
  # Compile-time scalar constants use UPPER_CASE (above) so the two
  # categories are visually distinct; macros keep their PYXIS_ prefix on
  # top of UPPER_CASE.
  readability-identifier-naming.EnumConstantCase:          CamelCase

  # Performance: avoid silent surprise from copies in range-based for.
  performance-for-range-copy.WarnOnAllAutoCopies: true

  # Identifier length — Pyxis house preference: variable / parameter
  # names should be explicit ("the name reads like the role"). One-
  # letter locals are forbidden outside conventional loop indices
  # (i, j, k). The earlier `cl → commandList`, `dm → deviceManager`,
  # `r → result` cleanups codify this rule; the build now blocks
  # regressions.
  readability-identifier-length.MinimumVariableNameLength:   3
  readability-identifier-length.MinimumParameterNameLength:  3
  readability-identifier-length.MinimumLoopCounterNameLength: 3
  readability-identifier-length.MinimumExceptionNameLength:  2
  # `i` / `it` / `id` stay legal for loop counters only — anything
  # else gets flagged. Add genuinely-conventional short names here if
  # they survive review (none today).
  readability-identifier-length.IgnoredVariableNames:        ''
  readability-identifier-length.IgnoredParameterNames:       ''
  readability-identifier-length.IgnoredLoopCounterNames:     '^[ijk]$'

  # Modernize: keep changes opt-in to avoid massive auto-rewrites.
  modernize-use-default-member-init.UseAssignment: true
