#usda 1.0
(
    defaultPrim = "World"
    metersPerUnit = 1
    upAxis = "Y"
    doc = "Pyxis M15 / V2.A.5 fixture — UsdVolVolume detect-warn-skip stub. Authors one UsdVolVolume (with an empty OpenVDBAsset reference; we never decode it) alongside one Cube so the scene still renders. The smoke test asserts pyxis exits 0 + EXR non-trivial + the volume warning log line fires."
)

def Xform "World"
{
    # Visible cube — proves the rest of the pipeline still renders past
    # the volume.
    def Cube "VisibleCube"
    {
        double size = 1.0
        color3f[] primvars:displayColor = [(0.6, 0.4, 0.8)]
        double3 xformOp:translate = (0, 1, 0)
        uniform token[] xformOpOrder = ["xformOp:translate"]
    }

    # UsdVolVolume — must be detected + warned + skipped. We don't even
    # author an OpenVDBAsset child since the stub doesn't try to decode.
    def Volume "VolumeStub"
    {
        double3 xformOp:translate = (2, 1, 0)
        uniform token[] xformOpOrder = ["xformOp:translate"]
    }

    def Camera "Camera"
    {
        float focalLength = 35.0
        float horizontalAperture = 36.0
        float verticalAperture = 20.25
        float2 clippingRange = (0.1, 1000)
        double3 xformOp:translate = (0, 1.5, 6)
        uniform token[] xformOpOrder = ["xformOp:translate"]
    }

    def DomeLight "DomeLight"
    {
        color3f inputs:color = (1, 1, 1)
        float inputs:intensity = 1.0
    }
}
