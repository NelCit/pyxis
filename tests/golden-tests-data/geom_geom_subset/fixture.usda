#usda 1.0
(
    defaultPrim = "World"
    metersPerUnit = 1
    upAxis = "Y"
    doc = "Pyxis golden geom_geom_subset — single 4-quad mesh with two UsdGeomSubsets routing different face sets to two materials. M5 / V2.A.18 — StageWalker emits one PreparedSubMesh per subset; the per-subset material binding wins over the prim-level fallback."
)
def Xform "World"
{
    def Mesh "Stripes" (
        prepend apiSchemas = ["MaterialBindingAPI"]
    )
    {
        uniform token subdivisionScheme = "none"
        int[] faceVertexCounts = [3, 3, 3, 3, 3, 3, 3, 3]
        int[] faceVertexIndices = [
            0, 1, 5, 0, 5, 4,        # face 0 (red)
            1, 2, 6, 1, 6, 5,        # face 1 (blue)
            2, 3, 7, 2, 7, 6,        # face 2 (red)
            4, 5, 9, 4, 9, 8         # face 3 — out of range; trimmed
        ]
        point3f[] points = [
            (-1.5, 0, -1), (-0.5, 0, -1), ( 0.5, 0, -1), ( 1.5, 0, -1),
            (-1.5, 0,  0), (-0.5, 0,  0), ( 0.5, 0,  0), ( 1.5, 0,  0),
            (-1.5, 0,  1), ( 1.5, 0,  1)
        ]
        rel material:binding = </World/Materials/Red>
        def GeomSubset "BlueStripe" (
            prepend apiSchemas = ["MaterialBindingAPI"]
        )
        {
            uniform token elementType = "face"
            uniform token familyName = "materialBind"
            int[] indices = [1, 3]
            rel material:binding = </World/Materials/Blue>
        }
    }
    def Scope "Materials"
    {
        def Material "Red"
        {
            token outputs:surface.connect = </World/Materials/Red/Surface.outputs:surface>
            def Shader "Surface"
            {
                uniform token info:id = "UsdPreviewSurface"
                color3f inputs:diffuseColor = (0.85, 0.20, 0.20)
                token outputs:surface
            }
        }
        def Material "Blue"
        {
            token outputs:surface.connect = </World/Materials/Blue/Surface.outputs:surface>
            def Shader "Surface"
            {
                uniform token info:id = "UsdPreviewSurface"
                color3f inputs:diffuseColor = (0.20, 0.40, 0.85)
                token outputs:surface
            }
        }
    }
    def Camera "Camera"
    {
        float focalLength = 35.0
        float horizontalAperture = 36.0
        float verticalAperture = 20.25
        float2 clippingRange = (0.1, 1000)
        double3 xformOp:translate = (0, 2.5, 3)
        float xformOp:rotateX = -45
        uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:rotateX"]
    }
    def DomeLight "DomeLight"
    {
        color3f inputs:color = (1, 1, 1)
        float inputs:intensity = 1.0
    }
}
