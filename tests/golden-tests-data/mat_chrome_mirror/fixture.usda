#usda 1.0
(
    defaultPrim = "World"
    metersPerUnit = 1
    upAxis = "Y"
    doc = "Pyxis golden mat_chrome_mirror — UsdPreviewSurface with metallic=1 + roughness=0. M30 — closesthit's reflection branch fires; with roughness 0 the GGX VNDF collapses to the mirror direction."
)
def Xform "World"
{
    def Sphere "Sphere" (
        prepend apiSchemas = ["MaterialBindingAPI"]
    )
    {
        double radius = 0.7
        double3 xformOp:translate = (0, 1, 0)
        uniform token[] xformOpOrder = ["xformOp:translate"]
        rel material:binding = </World/Materials/Chrome>
    }
    def Cube "FloorCube"
    {
        double size = 5
        color3f[] primvars:displayColor = [(0.30, 0.65, 0.20)]
        double3 xformOp:translate = (0, -2.5, 0)
        uniform token[] xformOpOrder = ["xformOp:translate"]
    }
    def Scope "Materials"
    {
        def Material "Chrome"
        {
            token outputs:surface.connect = </World/Materials/Chrome/Surface.outputs:surface>
            def Shader "Surface"
            {
                uniform token info:id = "UsdPreviewSurface"
                color3f inputs:diffuseColor = (1, 1, 1)
                float inputs:metallic = 1.0
                float inputs:roughness = 0.02
                token outputs:surface
            }
        }
    }
    def Camera "Camera"
    {
        float focalLength = 35.0
        float horizontalAperture = 36.0
        float verticalAperture = 20.25
        float2 clippingRange = (0.1, 1000)
        double3 xformOp:translate = (0, 1.4, 3)
        uniform token[] xformOpOrder = ["xformOp:translate"]
    }
    def DomeLight "DomeLight"
    {
        color3f inputs:color = (0.9, 0.95, 1.0)
        float inputs:intensity = 1.5
    }
}
