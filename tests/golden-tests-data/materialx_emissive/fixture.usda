#usda 1.0
(
    defaultPrim = "World"
    metersPerUnit = 1
    upAxis = "Y"
    doc = "Pyxis golden materialx_emissive — MaterialX ND_open_pbr_surface with non-zero emission_color + emission_luminance. V2.A.8 — emission translates via the OpenPBR MaterialX branch."
)
def Xform "World"
{
    def Sphere "Glow" (
        prepend apiSchemas = ["MaterialBindingAPI"]
    )
    {
        double radius = 0.7
        double3 xformOp:translate = (0, 1, 0)
        uniform token[] xformOpOrder = ["xformOp:translate"]
        rel material:binding = </World/Materials/Emit>
    }
    def Scope "Materials"
    {
        def Material "Emit"
        {
            token outputs:surface.connect = </World/Materials/Emit/Surface.outputs:surface>
            def Shader "Surface"
            {
                uniform token info:id = "ND_open_pbr_surface_surfaceshader"
                color3f inputs:base_color = (0.05, 0.05, 0.05)
                float inputs:base_weight = 1.0
                float inputs:base_metalness = 0.0
                float inputs:specular_roughness = 0.5
                color3f inputs:emission_color = (0.95, 0.40, 0.10)
                float inputs:emission_luminance = 5.0
                token outputs:surface
            }
        }
    }
    def Camera "Camera"
    {
        float focalLength = 35.0
        float horizontalAperture = 36.0
        float verticalAperture = 20.25
        float2 clippingRange = (0.1, 1000)
        double3 xformOp:translate = (0, 1.4, 3)
        uniform token[] xformOpOrder = ["xformOp:translate"]
    }
}
