#usda 1.0
(
    defaultPrim = "World"
    metersPerUnit = 1
    upAxis = "Y"
    doc = "Pyxis golden light_rect_aspect_nonsquare — UsdLuxRectLight with width = 3, height = 0.5 (existing light_rect uses 2×2 square). Strip-light geometry should distribute illumination along the long axis differently from the short. Catches regressions where the rect dimensions are squashed to a single value (both axes use width, or both use height)."
)

def Xform "World"
{
    def Sphere "Target"
    {
        double radius = 0.7
        color3f[] primvars:displayColor = [(0.85, 0.85, 0.85)]
        double3 xformOp:translate = (0, 1, 0)
        uniform token[] xformOpOrder = ["xformOp:translate"]
    }

    def RectLight "Strip"
    {
        color3f inputs:color = (1, 1, 1)
        float inputs:intensity = 80
        float inputs:width  = 3.0
        float inputs:height = 0.5
        double3 xformOp:translate = (0, 3, 0)
        float xformOp:rotateX = -90
        uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:rotateX"]
    }

    def Camera "Camera"
    {
        float focalLength = 35.0
        float horizontalAperture = 36.0
        float verticalAperture = 20.25
        float2 clippingRange = (0.1, 1000)
        double3 xformOp:translate = (0, 1.4, 3)
        uniform token[] xformOpOrder = ["xformOp:translate"]
    }
}
