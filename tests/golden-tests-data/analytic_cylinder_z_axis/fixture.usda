#usda 1.0
(
    defaultPrim = "World"
    metersPerUnit = 1
    upAxis = "Y"
    doc = "Pyxis golden analytic_cylinder_z_axis — UsdGeomCylinder axis=Z (the USD default). Validates the Z-axis side+caps tessellation."
)
def Xform "World"
{
    def Cylinder "Subject"
    {
        double radius = 0.5
        double height = 1.6
        uniform token axis = "Z"
        color3f[] primvars:displayColor = [(0.30, 0.55, 0.85)]
        double3 xformOp:translate = (0, 1, 0)
        uniform token[] xformOpOrder = ["xformOp:translate"]
    }
    def Camera "Camera"
    {
        float focalLength = 35.0
        float horizontalAperture = 36.0
        float verticalAperture = 20.25
        float2 clippingRange = (0.1, 1000)
        double3 xformOp:translate = (1.5, 1.4, 1.6)
        float xformOp:rotateY = 30
        uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:rotateY"]
    }
    def DomeLight "DomeLight"
    {
        color3f inputs:color = (1, 1, 1)
        float inputs:intensity = 1.2
    }
}
