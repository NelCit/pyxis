#usda 1.0
(
    defaultPrim = "World"
    metersPerUnit = 1
    upAxis = "Y"
    doc = "Pyxis golden scene_empty_dome_only — Camera + DomeLight only, NO geometry. Every raygen ray misses; the closesthit never fires. The image must be the dome's lat-long sample (uniform color here since the dome is constant white). Catches regressions where (a) the miss shader emits black instead of the dome, (b) the renderer crashes on an empty TLAS, or (c) the BLAS-less path silently early-outs to a no-write state."
)

def Xform "World"
{
    def Camera "Camera"
    {
        float focalLength = 35.0
        float horizontalAperture = 36.0
        float verticalAperture = 20.25
        float2 clippingRange = (0.1, 1000)
        double3 xformOp:translate = (0, 1, 3)
        uniform token[] xformOpOrder = ["xformOp:translate"]
    }

    def DomeLight "DomeLight"
    {
        color3f inputs:color = (0.40, 0.65, 0.85)
        float inputs:intensity = 1.0
    }
}
