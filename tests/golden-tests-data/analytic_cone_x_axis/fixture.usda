#usda 1.0
(
    defaultPrim = "World"
    metersPerUnit = 1
    upAxis = "Y"
    doc = "Pyxis golden analytic_cone_x_axis — UsdGeomCone with axis=X. Pins AnalyticGeom::TessellateCone's ResolveAxisFrame branch for the non-default axis."
)
def Xform "World"
{
    def Cone "Subject"
    {
        double radius = 0.7
        double height = 1.6
        uniform token axis = "X"
        color3f[] primvars:displayColor = [(0.50, 0.80, 0.40)]
        double3 xformOp:translate = (0, 1, 0)
        uniform token[] xformOpOrder = ["xformOp:translate"]
    }
    def Camera "Camera"
    {
        float focalLength = 35.0
        float horizontalAperture = 36.0
        float verticalAperture = 20.25
        float2 clippingRange = (0.1, 1000)
        double3 xformOp:translate = (0, 1.5, 4)
        uniform token[] xformOpOrder = ["xformOp:translate"]
    }
    def DomeLight "DomeLight"
    {
        color3f inputs:color = (1, 1, 1)
        float inputs:intensity = 1.2
    }
}
