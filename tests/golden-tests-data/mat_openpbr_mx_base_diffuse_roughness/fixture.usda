#usda 1.0
(
    defaultPrim = "World"
    metersPerUnit = 1
    upAxis = "Y"
    doc = "Pyxis golden mat_openpbr_mx_base_diffuse_roughness — MaterialX open_pbr_surface dielectric with base_diffuse_roughness = 0.85 (Oren-Nayar). The retro-reflective rim must show vs an otherwise-identical Lambert reference (mat_materialx_openpbr). §11 / OpenPBR — base_diffuse_roughness drives the Oren-Nayar microfacet diffuse model; at 0 it collapses to Lambert."
)

def Xform "World"
{
    def Sphere "Sphere" (
        prepend apiSchemas = ["MaterialBindingAPI"]
    )
    {
        double radius = 0.7
        double3 xformOp:translate = (0, 1, 0)
        uniform token[] xformOpOrder = ["xformOp:translate"]
        rel material:binding = </World/Materials/Chalk>
    }

    def Scope "Materials"
    {
        def Material "Chalk"
        {
            token outputs:surface.connect = </World/Materials/Chalk/Surface.outputs:surface>

            def Shader "Surface"
            {
                uniform token info:id = "ND_open_pbr_surface_surfaceshader"
                color3f inputs:base_color = (0.85, 0.85, 0.82)
                float inputs:base_weight = 1.0
                float inputs:base_metalness = 0.0
                float inputs:base_diffuse_roughness = 0.85
                float inputs:specular_weight = 0.0
                float inputs:specular_roughness = 0.5
                float inputs:specular_ior = 1.45
                token outputs:surface
            }
        }
    }

    def Camera "Camera"
    {
        float focalLength = 35.0
        float horizontalAperture = 36.0
        float verticalAperture = 20.25
        float2 clippingRange = (0.1, 1000)
        double3 xformOp:translate = (0, 1.4, 3)
        uniform token[] xformOpOrder = ["xformOp:translate"]
    }

    def DomeLight "DomeLight"
    {
        color3f inputs:color = (1, 1, 1)
        float inputs:intensity = 1.5
    }
}
