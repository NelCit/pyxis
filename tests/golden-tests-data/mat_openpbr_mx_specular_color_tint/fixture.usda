#usda 1.0
(
    defaultPrim = "World"
    metersPerUnit = 1
    upAxis = "Y"
    doc = "Pyxis golden mat_openpbr_mx_specular_color_tint — dielectric (base_metalness=0) MaterialX open_pbr_surface with a strongly-tinted specular_color = (0.4, 1.0, 0.55). For non-metals, specular_color tints the Fresnel-weighted lobe; UsdPreviewSurface has no equivalent unless useSpecularWorkflow=1. §11."
)

def Xform "World"
{
    def Sphere "Sphere" (
        prepend apiSchemas = ["MaterialBindingAPI"]
    )
    {
        double radius = 0.7
        double3 xformOp:translate = (0, 1, 0)
        uniform token[] xformOpOrder = ["xformOp:translate"]
        rel material:binding = </World/Materials/GreenSpec>
    }

    def Scope "Materials"
    {
        def Material "GreenSpec"
        {
            token outputs:surface.connect = </World/Materials/GreenSpec/Surface.outputs:surface>

            def Shader "Surface"
            {
                uniform token info:id = "ND_open_pbr_surface_surfaceshader"
                color3f inputs:base_color = (0.35, 0.10, 0.10)
                float inputs:base_weight = 1.0
                float inputs:base_metalness = 0.0
                float inputs:specular_weight = 1.0
                color3f inputs:specular_color = (0.40, 1.0, 0.55)
                float inputs:specular_roughness = 0.20
                float inputs:specular_ior = 1.45
                token outputs:surface
            }
        }
    }

    def Camera "Camera"
    {
        float focalLength = 35.0
        float horizontalAperture = 36.0
        float verticalAperture = 20.25
        float2 clippingRange = (0.1, 1000)
        double3 xformOp:translate = (0, 1.4, 3)
        uniform token[] xformOpOrder = ["xformOp:translate"]
    }

    def DomeLight "DomeLight"
    {
        color3f inputs:color = (1, 1, 1)
        float inputs:intensity = 1.5
    }
}
