#usda 1.0
(
    defaultPrim = "World"
    metersPerUnit = 1
    upAxis = "Y"
    doc = "Pyxis golden camera_aperture_wide — Cube + dome, camera with horizontalAperture = 55mm (vs the default 36mm). Wider aperture at the same focal length = wider field of view; the cube must appear visibly smaller than the default-aperture twin. Catches regressions where aperture is hardcoded to a constant or lost during the projection matrix build."
)

def Xform "World"
{
    def Cube "Cube"
    {
        double size = 1.2
        color3f[] primvars:displayColor = [(0.30, 0.65, 0.80)]
        double3 xformOp:translate = (0, 1, 0)
        uniform token[] xformOpOrder = ["xformOp:translate"]
    }

    def Camera "Camera"
    {
        float focalLength = 35.0
        # Wide horizontal aperture — increases horizontal FoV ~50%.
        float horizontalAperture = 55.0
        float verticalAperture = 30.9
        float2 clippingRange = (0.1, 1000)
        double3 xformOp:translate = (0, 1, 3.5)
        uniform token[] xformOpOrder = ["xformOp:translate"]
    }

    def DomeLight "DomeLight"
    {
        color3f inputs:color = (1, 1, 1)
        float inputs:intensity = 1.0
    }
}
