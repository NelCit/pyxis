#usda 1.0
(
    defaultPrim = "World"
    metersPerUnit = 1
    upAxis = "Y"
    doc = "Pyxis golden mat_openpbr_mx_coat_full — MaterialX open_pbr_surface with coat_weight=1.0, coat_color=(1.0,0.85,0.65) (warm tint), coat_roughness=0.05, coat_ior=1.55. Differs from the UsdPreviewSurface clearcoat path (mat_clearcoat) in two ways: (a) authored as the MaterialX shader directly so the open_pbr→OpenPBRMaterialGPU mapping path is exercised, and (b) the coat tint actually colors the secondary lobe (UsdPreviewSurface has no clearcoatColor input). §11."
)

def Xform "World"
{
    def Sphere "Sphere" (
        prepend apiSchemas = ["MaterialBindingAPI"]
    )
    {
        double radius = 0.7
        double3 xformOp:translate = (0, 1, 0)
        uniform token[] xformOpOrder = ["xformOp:translate"]
        rel material:binding = </World/Materials/TintedCoat>
    }

    def Scope "Materials"
    {
        def Material "TintedCoat"
        {
            token outputs:surface.connect = </World/Materials/TintedCoat/Surface.outputs:surface>

            def Shader "Surface"
            {
                uniform token info:id = "ND_open_pbr_surface_surfaceshader"
                color3f inputs:base_color = (0.20, 0.25, 0.55)
                float inputs:base_weight = 1.0
                float inputs:base_metalness = 0.0
                float inputs:specular_roughness = 0.30
                float inputs:specular_weight = 1.0
                float inputs:specular_ior = 1.45
                float inputs:coat_weight = 1.0
                color3f inputs:coat_color = (1.0, 0.85, 0.65)
                float inputs:coat_roughness = 0.05
                float inputs:coat_ior = 1.55
                token outputs:surface
            }
        }
    }

    def Camera "Camera"
    {
        float focalLength = 35.0
        float horizontalAperture = 36.0
        float verticalAperture = 20.25
        float2 clippingRange = (0.1, 1000)
        double3 xformOp:translate = (0, 1.4, 3)
        uniform token[] xformOpOrder = ["xformOp:translate"]
    }

    def DomeLight "DomeLight"
    {
        color3f inputs:color = (1, 1, 1)
        float inputs:intensity = 1.5
    }
}
