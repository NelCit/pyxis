#usda 1.0
(
    defaultPrim = "World"
    metersPerUnit = 1
    upAxis = "Y"
    doc = "Pyxis golden instancer_with_scales_and_orientations — UsdGeomPointInstancer with BOTH scales[] and orientations[] arrays authored. Three cubes at progressively bigger scales AND rotating about Y. The composed per-instance world transform must apply translate · orient · scale in the right order. Catches regressions where the two arrays don't compose correctly (e.g. one short-circuits the other)."
)

def Xform "World"
{
    def PointInstancer "Instancer"
    {
        rel prototypes = [</World/Instancer/Prototypes/Cube>]
        int[] protoIndices = [0, 0, 0]
        point3f[] positions = [
            (-1.4, 0.5, 0), (0, 0.5, 0), (1.4, 0.5, 0)
        ]
        float3[] scales = [
            (0.5, 0.5, 0.5), (0.9, 0.9, 0.9), (1.3, 1.3, 1.3)
        ]
        quath[] orientations = [
            (1.0,      0, 0,         0),
            (0.965926, 0, 0.258819,  0),    # 30°
            (0.866025, 0, 0.5,       0)     # 60°
        ]

        def Scope "Prototypes"
        {
            def Mesh "Cube"
            {
                uniform token subdivisionScheme = "none"
                int[] faceVertexCounts = [3, 3, 3, 3, 3, 3, 3, 3, 3, 3, 3, 3]
                int[] faceVertexIndices = [
                    0, 1, 2,  0, 2, 3,
                    4, 6, 5,  4, 7, 6,
                    0, 4, 5,  0, 5, 1,
                    1, 5, 6,  1, 6, 2,
                    2, 6, 7,  2, 7, 3,
                    3, 7, 4,  3, 4, 0
                ]
                point3f[] points = [
                    (-0.40, -0.40,  0.40), ( 0.40, -0.40,  0.40),
                    ( 0.40, -0.40, -0.40), (-0.40, -0.40, -0.40),
                    (-0.40,  0.40,  0.40), ( 0.40,  0.40,  0.40),
                    ( 0.40,  0.40, -0.40), (-0.40,  0.40, -0.40)
                ]
                color3f[] primvars:displayColor = [(0.30, 0.65, 0.85)]
            }
        }
    }

    def Camera "Camera"
    {
        float focalLength = 35.0
        float horizontalAperture = 36.0
        float verticalAperture = 20.25
        float2 clippingRange = (0.1, 1000)
        double3 xformOp:translate = (0, 2, 3.5)
        float xformOp:rotateX = -25
        uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:rotateX"]
    }

    def DomeLight "DomeLight"
    {
        color3f inputs:color = (1, 1, 1)
        float inputs:intensity = 1.0
    }
}
