#usda 1.0
(
    defaultPrim = "World"
    metersPerUnit = 1
    upAxis = "Y"
    doc = "Pyxis golden xform_scale — three Spheres with distinct non-uniform xformOp:scale values. V2.A.6 — UsdGeomXformCache composition picks up the scale onto worldFromLocal."
)
def Xform "World"
{
    def Sphere "Tall" {
        double radius = 0.5
        color3f[] primvars:displayColor = [(0.85, 0.25, 0.25)]
        double3 xformOp:translate = (-1.5, 1, 0)
        float3 xformOp:scale = (0.5, 1.5, 0.5)
        uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:scale"]
    }
    def Sphere "Wide" {
        double radius = 0.5
        color3f[] primvars:displayColor = [(0.25, 0.85, 0.25)]
        double3 xformOp:translate = (0, 1, 0)
        float3 xformOp:scale = (1.5, 0.5, 0.5)
        uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:scale"]
    }
    def Sphere "Big" {
        double radius = 0.5
        color3f[] primvars:displayColor = [(0.25, 0.45, 0.85)]
        double3 xformOp:translate = (1.5, 1, 0)
        float3 xformOp:scale = (1.2, 1.2, 1.2)
        uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:scale"]
    }
    def Camera "Camera" {
        float focalLength = 35.0
        float horizontalAperture = 36.0
        float verticalAperture = 20.25
        float2 clippingRange = (0.1, 1000)
        double3 xformOp:translate = (0, 1.5, 5)
        uniform token[] xformOpOrder = ["xformOp:translate"]
    }
    def DomeLight "DomeLight"
    {
        color3f inputs:color = (1, 1, 1)
        float inputs:intensity = 1.0
    }
}
