#usda 1.0
(
    defaultPrim = "World"
    metersPerUnit = 1
    upAxis = "Y"
    doc = "Pyxis golden variantset_cli_override — same fixture as variantset_authored_default (stage default = look:small_red); regression.json passes --variant /World/VariantSubject:look=big_blue. The session-layer override wins → big blue cube at a different position. Pins the V2.A.2 CLI-override path (UsdEditContext on GetSessionLayer + SetVariantSelection)."
)
def Xform "World"
{
    def Cube "VariantSubject" (
        prepend variantSets = "look"
        variants = {
            string look = "small_red"
        }
    )
    {
        variantSet "look" = {
            "small_red" {
                double size = 1.0
                color3f[] primvars:displayColor = [(0.85, 0.20, 0.20)]
                double3 xformOp:translate = (-1.2, 0.5, 0)
                uniform token[] xformOpOrder = ["xformOp:translate"]
            }
            "big_blue" {
                double size = 2.0
                color3f[] primvars:displayColor = [(0.20, 0.30, 0.85)]
                double3 xformOp:translate = (1.2, 1.0, 0)
                uniform token[] xformOpOrder = ["xformOp:translate"]
            }
        }
    }
    def Camera "Camera"
    {
        float focalLength = 35.0
        float horizontalAperture = 36.0
        float verticalAperture = 20.25
        float2 clippingRange = (0.1, 1000)
        double3 xformOp:translate = (0, 1.5, 5)
        uniform token[] xformOpOrder = ["xformOp:translate"]
    }
    def DomeLight "DomeLight"
    {
        color3f inputs:color = (1, 1, 1)
        float inputs:intensity = 1.2
    }
}
