#usda 1.0
(
    defaultPrim = "World"
    metersPerUnit = 1
    upAxis = "Y"
    doc = "Pyxis golden light_dome — single Sphere lit by a UsdLuxDomeLight, no other lights. M7 — closesthit's M7-simple Lambertian-against-up dome contribution + miss-shader sky."
)

def Xform "World"
{
    def Sphere "Sphere"
    {
        double radius = 0.7
        color3f[] primvars:displayColor = [(0.7, 0.7, 0.7)]
        double3 xformOp:translate = (0, 1, 0)
        uniform token[] xformOpOrder = ["xformOp:translate"]
    }

    def Camera "Camera"
    {
        float focalLength = 35.0
        float horizontalAperture = 36.0
        float verticalAperture = 20.25
        float2 clippingRange = (0.1, 1000)
        double3 xformOp:translate = (0, 1.4, 3)
        uniform token[] xformOpOrder = ["xformOp:translate"]
    }

    def DomeLight "DomeLight"
    {
        color3f inputs:color = (0.55, 0.70, 1.0)
        float inputs:intensity = 1.5
    }
}
