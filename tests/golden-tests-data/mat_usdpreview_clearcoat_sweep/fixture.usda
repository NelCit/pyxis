#usda 1.0
(
    defaultPrim = "World"
    metersPerUnit = 1
    upAxis = "Y"
    doc = "Pyxis golden mat_usdpreview_clearcoat_sweep — three spheres at clearcoat = (0.0, 0.5, 1.0). All other fields fixed (red base, metallic=0.3, roughness=0.4, clearcoatRoughness=0.05). M30 — proves the clearcoat lobe is additive over the base rather than replacing it. Catches regressions where clearcoat is binarized (off vs on) or where the inter-lobe energy compensation drops out."
)

def Xform "World"
{
    def Sphere "SphereC00" (
        prepend apiSchemas = ["MaterialBindingAPI"]
    )
    {
        double radius = 0.55
        double3 xformOp:translate = (-1.4, 1, 0)
        uniform token[] xformOpOrder = ["xformOp:translate"]
        rel material:binding = </World/Materials/M_C00>
    }
    def Sphere "SphereC05" (
        prepend apiSchemas = ["MaterialBindingAPI"]
    )
    {
        double radius = 0.55
        double3 xformOp:translate = (0, 1, 0)
        uniform token[] xformOpOrder = ["xformOp:translate"]
        rel material:binding = </World/Materials/M_C05>
    }
    def Sphere "SphereC10" (
        prepend apiSchemas = ["MaterialBindingAPI"]
    )
    {
        double radius = 0.55
        double3 xformOp:translate = (1.4, 1, 0)
        uniform token[] xformOpOrder = ["xformOp:translate"]
        rel material:binding = </World/Materials/M_C10>
    }

    def Scope "Materials"
    {
        def Material "M_C00"
        {
            token outputs:surface.connect = </World/Materials/M_C00/S.outputs:surface>
            def Shader "S"
            {
                uniform token info:id = "UsdPreviewSurface"
                color3f inputs:diffuseColor = (0.85, 0.15, 0.15)
                float inputs:metallic = 0.3
                float inputs:roughness = 0.4
                float inputs:clearcoat = 0.0
                float inputs:clearcoatRoughness = 0.05
                token outputs:surface
            }
        }
        def Material "M_C05"
        {
            token outputs:surface.connect = </World/Materials/M_C05/S.outputs:surface>
            def Shader "S"
            {
                uniform token info:id = "UsdPreviewSurface"
                color3f inputs:diffuseColor = (0.85, 0.15, 0.15)
                float inputs:metallic = 0.3
                float inputs:roughness = 0.4
                float inputs:clearcoat = 0.5
                float inputs:clearcoatRoughness = 0.05
                token outputs:surface
            }
        }
        def Material "M_C10"
        {
            token outputs:surface.connect = </World/Materials/M_C10/S.outputs:surface>
            def Shader "S"
            {
                uniform token info:id = "UsdPreviewSurface"
                color3f inputs:diffuseColor = (0.85, 0.15, 0.15)
                float inputs:metallic = 0.3
                float inputs:roughness = 0.4
                float inputs:clearcoat = 1.0
                float inputs:clearcoatRoughness = 0.05
                token outputs:surface
            }
        }
    }

    def Camera "Camera"
    {
        float focalLength = 35.0
        float horizontalAperture = 36.0
        float verticalAperture = 20.25
        float2 clippingRange = (0.1, 1000)
        double3 xformOp:translate = (0, 1.3, 4.2)
        uniform token[] xformOpOrder = ["xformOp:translate"]
    }

    def DomeLight "DomeLight"
    {
        color3f inputs:color = (1, 1, 1)
        float inputs:intensity = 1.5
    }
}
