#usda 1.0
(
    defaultPrim = "World"
    metersPerUnit = 1
    upAxis = "Y"
    doc = "Pyxis golden geom_subdiv_loop — UsdGeomMesh::subdivisionScheme = loop. V2.A.1 — OpenSubdiv refines via the Loop scheme (triangles only, splits each tri into 4)."
)
def Xform "World"
{
    def Mesh "TriCage"
    {
        uniform token subdivisionScheme = "loop"
        # Tetrahedron — 4 verts, 4 triangles. Loop refines to a smooth blob.
        int[] faceVertexCounts = [3, 3, 3, 3]
        int[] faceVertexIndices = [
            0, 1, 2,    # bottom
            0, 2, 3,    # right
            0, 3, 1,    # left
            1, 3, 2     # top
        ]
        point3f[] points = [
            ( 0.0, -0.5,  0.6),
            (-0.6, -0.5, -0.4),
            ( 0.6, -0.5, -0.4),
            ( 0.0,  0.7,  0.0)
        ]
        color3f[] primvars:displayColor = [(0.5, 0.85, 0.55)]
    }
    def Camera "Camera"
    {
        float focalLength = 35.0
        float horizontalAperture = 36.0
        float verticalAperture = 20.25
        float2 clippingRange = (0.1, 1000)
        double3 xformOp:translate = (1.5, 1.0, 1.6)
        float xformOp:rotateY = 30
        float xformOp:rotateX = -15
        uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:rotateY", "xformOp:rotateX"]
    }
    def DomeLight "DomeLight"
    {
        color3f inputs:color = (1, 1, 1)
        float inputs:intensity = 1.2
    }
}
