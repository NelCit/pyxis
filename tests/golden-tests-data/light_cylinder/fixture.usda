#usda 1.0
(
    defaultPrim = "World"
    metersPerUnit = 1
    upAxis = "Y"
    doc = "Pyxis golden light_cylinder — UsdLuxCylinderLight (tube light). M8a UsdLux coverage."
)
def Xform "World"
{
    def Cube "Subject"
    {
        double size = 1.0
        color3f[] primvars:displayColor = [(0.5, 0.85, 0.65)]
        double3 xformOp:translate = (0, 0.5, 0)
        uniform token[] xformOpOrder = ["xformOp:translate"]
    }
    def CylinderLight "Tube"
    {
        color3f inputs:color = (1, 1, 0.9)
        float inputs:intensity = 60
        float inputs:length = 2.5
        float inputs:radius = 0.15
        double3 xformOp:translate = (0, 2.5, 0.4)
        float xformOp:rotateZ = 90
        uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:rotateZ"]
    }
    def Camera "Camera"
    {
        float focalLength = 35.0
        float horizontalAperture = 36.0
        float verticalAperture = 20.25
        float2 clippingRange = (0.1, 1000)
        double3 xformOp:translate = (0, 1.5, 3)
        uniform token[] xformOpOrder = ["xformOp:translate"]
    }
}
