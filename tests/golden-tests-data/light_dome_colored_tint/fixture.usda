#usda 1.0
(
    defaultPrim = "World"
    metersPerUnit = 1
    upAxis = "Y"
    doc = "Pyxis golden light_dome_colored_tint — Sphere lit only by a warm-tinted DomeLight (color = (1.0, 0.55, 0.30)). M7 — proves DomeLight.color flows through EmitLight into the closesthit's Dome term (not just intensity). Orthogonal to light_dome (white)."
)

def Xform "World"
{
    def Sphere "Sphere"
    {
        double radius = 0.7
        color3f[] primvars:displayColor = [(0.85, 0.85, 0.85)]
        double3 xformOp:translate = (0, 1, 0)
        uniform token[] xformOpOrder = ["xformOp:translate"]
    }

    def Camera "Camera"
    {
        float focalLength = 35.0
        float horizontalAperture = 36.0
        float verticalAperture = 20.25
        float2 clippingRange = (0.1, 1000)
        double3 xformOp:translate = (0, 1.4, 3)
        uniform token[] xformOpOrder = ["xformOp:translate"]
    }

    def DomeLight "DomeLight"
    {
        color3f inputs:color = (1.0, 0.55, 0.30)
        float inputs:intensity = 1.5
    }
}
