#usda 1.0
(
    defaultPrim = "World"
    metersPerUnit = 1
    upAxis = "Y"
    doc = "Pyxis golden camera_aperture_offset — Camera with horizontalApertureOffset = 8mm (shifts the optical center off the image center). Used for tilt-shift photography or to match a real-world lens. Image-space content must appear shifted left. Catches regressions where aperture offsets are dropped during the projection matrix build."
)

def Xform "World"
{
    def Cube "Cube"
    {
        double size = 1.2
        color3f[] primvars:displayColor = [(0.45, 0.65, 0.85)]
        double3 xformOp:translate = (0, 1, 0)
        uniform token[] xformOpOrder = ["xformOp:translate"]
    }

    def Camera "Camera"
    {
        float focalLength = 35.0
        float horizontalAperture = 36.0
        float verticalAperture = 20.25
        # Shift the optical center +8mm right at the film plane → image-space
        # content appears shifted left.
        float horizontalApertureOffset = 8.0
        float verticalApertureOffset = 0.0
        float2 clippingRange = (0.1, 1000)
        double3 xformOp:translate = (0, 1, 3.5)
        uniform token[] xformOpOrder = ["xformOp:translate"]
    }

    def DomeLight "DomeLight"
    {
        color3f inputs:color = (1, 1, 1)
        float inputs:intensity = 1.0
    }
}
