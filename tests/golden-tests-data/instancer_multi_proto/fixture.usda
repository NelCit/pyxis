#usda 1.0
(
    defaultPrim = "World"
    metersPerUnit = 1
    upAxis = "Y"
    doc = "Pyxis golden instancer_multi_proto — PointInstancer with 2 prototypes (red cube + blue tetrahedron). M6 — protoIndices alternates between the two; closesthit AOVs would show two distinct material slots."
)
def Xform "World"
{
    def PointInstancer "Instancer"
    {
        rel prototypes = [
            </World/Instancer/Prototypes/RedCube>,
            </World/Instancer/Prototypes/BlueTet>
        ]
        int[] protoIndices = [0, 1, 0, 1]
        point3f[] positions = [
            (-1.5, 0.4, 0), (-0.5, 0.4, 0), (0.5, 0.4, 0), (1.5, 0.4, 0)
        ]
        def Scope "Prototypes"
        {
            def Mesh "RedCube"
            {
                uniform token subdivisionScheme = "none"
                int[] faceVertexCounts = [3, 3, 3, 3, 3, 3, 3, 3, 3, 3, 3, 3]
                int[] faceVertexIndices = [
                    0, 1, 2,  0, 2, 3,  4, 6, 5,  4, 7, 6,
                    0, 4, 5,  0, 5, 1,  1, 5, 6,  1, 6, 2,
                    2, 6, 7,  2, 7, 3,  3, 7, 4,  3, 4, 0
                ]
                point3f[] points = [
                    (-0.35, -0.35,  0.35), ( 0.35, -0.35,  0.35),
                    ( 0.35, -0.35, -0.35), (-0.35, -0.35, -0.35),
                    (-0.35,  0.35,  0.35), ( 0.35,  0.35,  0.35),
                    ( 0.35,  0.35, -0.35), (-0.35,  0.35, -0.35)
                ]
                color3f[] primvars:displayColor = [(0.85, 0.20, 0.20)]
            }
            def Mesh "BlueTet"
            {
                uniform token subdivisionScheme = "none"
                int[] faceVertexCounts = [3, 3, 3, 3]
                int[] faceVertexIndices = [0, 1, 2,  0, 2, 3,  0, 3, 1,  1, 3, 2]
                point3f[] points = [
                    ( 0.0, -0.35,  0.40),
                    (-0.40, -0.35, -0.25),
                    ( 0.40, -0.35, -0.25),
                    ( 0.0,  0.40,  0.0)
                ]
                color3f[] primvars:displayColor = [(0.20, 0.40, 0.85)]
            }
        }
    }
    def Camera "Camera"
    {
        float focalLength = 35.0
        float horizontalAperture = 36.0
        float verticalAperture = 20.25
        float2 clippingRange = (0.1, 1000)
        double3 xformOp:translate = (0, 2, 3)
        float xformOp:rotateX = -20
        uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:rotateX"]
    }
    def DomeLight "DomeLight"
    {
        color3f inputs:color = (1, 1, 1)
        float inputs:intensity = 1.0
    }
}
