#usda 1.0
(
    defaultPrim = "World"
    metersPerUnit = 1
    upAxis = "Y"
    doc = "Pyxis golden camera_roll_z — single Cube + dome, camera rotated 30° about its local Z axis (roll). Exercises xformOp:rotateZ on a Camera prim; the rendered cube must appear tilted relative to the image axes. Orthogonal to camera_focal_lengths (no rotation)."
)

def Xform "World"
{
    def Cube "Cube"
    {
        double size = 1.2
        color3f[] primvars:displayColor = [(0.85, 0.45, 0.25)]
        double3 xformOp:translate = (0, 1, 0)
        uniform token[] xformOpOrder = ["xformOp:translate"]
    }

    def Camera "Camera"
    {
        float focalLength = 35.0
        float horizontalAperture = 36.0
        float verticalAperture = 20.25
        float2 clippingRange = (0.1, 1000)
        # Translate first, then roll 30° about Z (right-handed → CCW from +Z).
        double3 xformOp:translate = (0, 1, 3.5)
        float xformOp:rotateZ = 30
        uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:rotateZ"]
    }

    def DomeLight "DomeLight"
    {
        color3f inputs:color = (1, 1, 1)
        float inputs:intensity = 1.2
    }
}
