#usda 1.0
(
    defaultPrim = "World"
    metersPerUnit = 1
    upAxis = "Y"
    doc = "Pyxis golden instancer_inactive_filter — UsdGeomPointInstancer authoring 6 instances but with inactiveIds = [1, 3] (a global cull list). Only instances 0, 2, 4, 5 render. Orthogonal to instancer_invisibleIds (which uses a per-frame visibility array): inactiveIds drops the instance from the persistent ECS state, invisibleIds toggles its visibility flag."
)

def Xform "World"
{
    def PointInstancer "Instancer"
    {
        rel prototypes = [</World/Instancer/Prototypes/Cube>]
        int[] protoIndices = [0, 0, 0, 0, 0, 0]
        point3f[] positions = [
            (-2.5, 0.4, 0), (-1.5, 0.4, 0), (-0.5, 0.4, 0),
            ( 0.5, 0.4, 0), ( 1.5, 0.4, 0), ( 2.5, 0.4, 0)
        ]
        int64[] inactiveIds = [1, 3]

        def Scope "Prototypes"
        {
            def Mesh "Cube"
            {
                uniform token subdivisionScheme = "none"
                int[] faceVertexCounts = [3, 3, 3, 3, 3, 3, 3, 3, 3, 3, 3, 3]
                int[] faceVertexIndices = [
                    0, 1, 2,  0, 2, 3,
                    4, 6, 5,  4, 7, 6,
                    0, 4, 5,  0, 5, 1,
                    1, 5, 6,  1, 6, 2,
                    2, 6, 7,  2, 7, 3,
                    3, 7, 4,  3, 4, 0
                ]
                point3f[] points = [
                    (-0.35, -0.35,  0.35), ( 0.35, -0.35,  0.35),
                    ( 0.35, -0.35, -0.35), (-0.35, -0.35, -0.35),
                    (-0.35,  0.35,  0.35), ( 0.35,  0.35,  0.35),
                    ( 0.35,  0.35, -0.35), (-0.35,  0.35, -0.35)
                ]
                color3f[] primvars:displayColor = [(0.80, 0.60, 0.30)]
            }
        }
    }

    def Camera "Camera"
    {
        float focalLength = 35.0
        float horizontalAperture = 36.0
        float verticalAperture = 20.25
        float2 clippingRange = (0.1, 1000)
        double3 xformOp:translate = (0, 2.5, 5)
        float xformOp:rotateX = -25
        uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:rotateX"]
    }

    def DomeLight "DomeLight"
    {
        color3f inputs:color = (1, 1, 1)
        float inputs:intensity = 1.0
    }
}
