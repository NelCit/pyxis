#usda 1.0
(
    defaultPrim = "World"
    metersPerUnit = 1
    upAxis = "Y"
    doc = "Pyxis golden light_sphere_radius_large — UsdLuxSphereLight at radius = 0.8 (existing light_sphere uses a small/default radius). Bigger emitter at the same intensity → wider falloff cone reaching the target sphere. Catches regressions where the radius attribute is dropped and the SphereLight collapses to a point."
)

def Xform "World"
{
    def Sphere "Target"
    {
        double radius = 0.55
        color3f[] primvars:displayColor = [(0.85, 0.85, 0.85)]
        double3 xformOp:translate = (0, 0.8, 0)
        uniform token[] xformOpOrder = ["xformOp:translate"]
    }

    def SphereLight "Emitter"
    {
        color3f inputs:color = (1, 1, 1)
        float inputs:intensity = 50
        float inputs:radius = 0.8
        double3 xformOp:translate = (1.6, 1.6, 0.4)
        uniform token[] xformOpOrder = ["xformOp:translate"]
    }

    def Camera "Camera"
    {
        float focalLength = 35.0
        float horizontalAperture = 36.0
        float verticalAperture = 20.25
        float2 clippingRange = (0.1, 1000)
        double3 xformOp:translate = (0, 1.2, 3)
        uniform token[] xformOpOrder = ["xformOp:translate"]
    }
}
