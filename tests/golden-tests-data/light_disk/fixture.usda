#usda 1.0
(
    defaultPrim = "World"
    metersPerUnit = 1
    upAxis = "Y"
    doc = "Pyxis golden light_disk — UsdLuxDiskLight illuminating a Cube. M8a — DiskLight registered as a Rect-family entry in EmitLight."
)
def Xform "World"
{
    def Cube "Subject"
    {
        double size = 0.9
        color3f[] primvars:displayColor = [(0.7, 0.55, 0.85)]
        double3 xformOp:translate = (0, 0.5, 0)
        uniform token[] xformOpOrder = ["xformOp:translate"]
    }
    def DiskLight "Lamp"
    {
        color3f inputs:color = (1, 0.85, 0.7)
        float inputs:intensity = 80
        float inputs:radius = 0.6
        double3 xformOp:translate = (0, 3, 0.5)
        float xformOp:rotateX = -90
        uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:rotateX"]
    }
    def Camera "Camera"
    {
        float focalLength = 35.0
        float horizontalAperture = 36.0
        float verticalAperture = 20.25
        float2 clippingRange = (0.1, 1000)
        double3 xformOp:translate = (0, 1.5, 3)
        uniform token[] xformOpOrder = ["xformOp:translate"]
    }
}
