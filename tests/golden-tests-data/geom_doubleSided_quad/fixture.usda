#usda 1.0
(
    defaultPrim = "World"
    metersPerUnit = 1
    upAxis = "Y"
    doc = "Pyxis golden geom_doubleSided_quad — single thin quad authored with its face normal pointing AWAY from the camera (vertices wound so geometric normal is +Z; camera sits at +Z). `doubleSided = true` forces the closesthit to render the back face. V2.A.x — pairs with the InstanceDoubleSided unit test. Without the doubleSided plumbing this golden would render an empty dome."
)

def Xform "World"
{
    def Mesh "Quad"
    {
        uniform token subdivisionScheme = "none"
        uniform bool doubleSided = true
        # Winding: bottom-left, bottom-right, top-right, top-left (when viewed
        # from -Z). Face normal points +Z. Camera at +Z is therefore looking
        # at the *back* of this quad — doubleSided must rescue the hit.
        int[] faceVertexCounts = [4]
        int[] faceVertexIndices = [0, 1, 2, 3]
        point3f[] points = [
            (-0.8, -0.8, 0), ( 0.8, -0.8, 0),
            ( 0.8,  0.8, 0), (-0.8,  0.8, 0)
        ]
        color3f[] primvars:displayColor = [(0.85, 0.55, 0.20)]
    }

    def Camera "Camera"
    {
        float focalLength = 35.0
        float horizontalAperture = 36.0
        float verticalAperture = 20.25
        float2 clippingRange = (0.1, 1000)
        double3 xformOp:translate = (0, 0, 2.5)
        uniform token[] xformOpOrder = ["xformOp:translate"]
    }

    def DomeLight "DomeLight"
    {
        color3f inputs:color = (1, 1, 1)
        float inputs:intensity = 1.2
    }
}
