#usda 1.0
(
    defaultPrim = "World"
    metersPerUnit = 1
    upAxis = "Y"
    doc = "Pyxis golden mat_clearcoat — UsdPreviewSurface with clearcoat=1 + clearcoatRoughness=0.05. OpenPBR coat lobe contributes a glossy second layer over the diffuse base."
)
def Xform "World"
{
    def Sphere "Sphere" (
        prepend apiSchemas = ["MaterialBindingAPI"]
    )
    {
        double radius = 0.7
        double3 xformOp:translate = (0, 1, 0)
        uniform token[] xformOpOrder = ["xformOp:translate"]
        rel material:binding = </World/Materials/CarPaint>
    }
    def Scope "Materials"
    {
        def Material "CarPaint"
        {
            token outputs:surface.connect = </World/Materials/CarPaint/Surface.outputs:surface>
            def Shader "Surface"
            {
                uniform token info:id = "UsdPreviewSurface"
                color3f inputs:diffuseColor = (0.85, 0.10, 0.10)
                float inputs:metallic = 0.3
                float inputs:roughness = 0.4
                float inputs:clearcoat = 1.0
                float inputs:clearcoatRoughness = 0.05
                token outputs:surface
            }
        }
    }
    def Camera "Camera"
    {
        float focalLength = 35.0
        float horizontalAperture = 36.0
        float verticalAperture = 20.25
        float2 clippingRange = (0.1, 1000)
        double3 xformOp:translate = (0, 1.4, 3)
        uniform token[] xformOpOrder = ["xformOp:translate"]
    }
    def DomeLight "DomeLight"
    {
        color3f inputs:color = (1, 1, 1)
        float inputs:intensity = 1.5
    }
}
