#usda 1.0
(
    defaultPrim = "World"
    metersPerUnit = 1
    upAxis = "Y"
    doc = "Pyxis golden light_sphere — UsdLuxSphereLight illuminating a Cube. M8a — UsdLuxSphereLight emit translation through EmitLight + closesthit shading."
)
def Xform "World"
{
    def Cube "Subject"
    {
        double size = 0.9
        color3f[] primvars:displayColor = [(0.7, 0.7, 0.7)]
        double3 xformOp:translate = (0, 0.5, 0)
        uniform token[] xformOpOrder = ["xformOp:translate"]
    }
    def SphereLight "Bulb"
    {
        color3f inputs:color = (1, 1, 0.6)
        float inputs:intensity = 200
        float inputs:radius = 0.2
        double3 xformOp:translate = (1.5, 1.5, 1.0)
        uniform token[] xformOpOrder = ["xformOp:translate"]
    }
    def Camera "Camera"
    {
        float focalLength = 35.0
        float horizontalAperture = 36.0
        float verticalAperture = 20.25
        float2 clippingRange = (0.1, 1000)
        double3 xformOp:translate = (0, 1.5, 3)
        uniform token[] xformOpOrder = ["xformOp:translate"]
    }
}
