#usda 1.0
(
    defaultPrim = "World"
    metersPerUnit = 1
    upAxis = "Y"
    doc = "Pyxis golden geom_lefthanded — UsdGeomMesh::orientation=leftHanded triggers the per-face winding flip in PrepareMesh. Without the flip the closesthit's CW backface cull would drop the visible side."
)

def Xform "World"
{
    def Mesh "Quad"
    {
        uniform token subdivisionScheme = "none"
        uniform token orientation = "leftHanded"
        int[] faceVertexCounts = [4]
        # CW order under leftHanded; the flip puts the visible side
        # facing +Y (towards the camera).
        int[] faceVertexIndices = [0, 1, 2, 3]
        point3f[] points = [(-1, 0, -1), (1, 0, -1), (1, 0, 1), (-1, 0, 1)]
        color3f[] primvars:displayColor = [(0.6, 0.3, 0.7)]
    }

    def Camera "Camera"
    {
        float focalLength = 35.0
        float horizontalAperture = 36.0
        float verticalAperture = 20.25
        float2 clippingRange = (0.1, 1000)
        double3 xformOp:translate = (0, 2.5, 3)
        float xformOp:rotateX = -45
        uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:rotateX"]
    }

    def DomeLight "DomeLight"
    {
        color3f inputs:color = (1, 1, 1)
        float inputs:intensity = 1.2
    }
}
