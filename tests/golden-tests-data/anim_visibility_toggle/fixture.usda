#usda 1.0
(
    defaultPrim = "World"
    metersPerUnit = 1
    upAxis = "Y"
    startTimeCode = 0
    endTimeCode = 100
    timeCodesPerSecond = 24
    doc = "Pyxis golden anim_visibility_toggle — two Cubes, each authored with `visibility` time-samples that flip at frame 50: Cube A is visible at frame 0..49 then invisible; Cube B is invisible at frame 0..49 then visible. Rendered at frame 60 = Cube B visible only. Tests that per-frame visibility evaluation reaches the renderer (vs frozen at load time). V2.A.13 time-code propagation."
)

def Xform "World"
{
    def Cube "CubeA"
    {
        double size = 1.0
        color3f[] primvars:displayColor = [(0.85, 0.30, 0.30)]
        double3 xformOp:translate = (-0.8, 1, 0)
        uniform token[] xformOpOrder = ["xformOp:translate"]
        token visibility.timeSamples = {
            0:  "inherited",
            49: "inherited",
            50: "invisible",
            100: "invisible",
        }
    }

    def Cube "CubeB"
    {
        double size = 1.0
        color3f[] primvars:displayColor = [(0.30, 0.55, 0.85)]
        double3 xformOp:translate = (0.8, 1, 0)
        uniform token[] xformOpOrder = ["xformOp:translate"]
        token visibility.timeSamples = {
            0:  "invisible",
            49: "invisible",
            50: "inherited",
            100: "inherited",
        }
    }

    def Camera "Camera"
    {
        float focalLength = 35.0
        float horizontalAperture = 36.0
        float verticalAperture = 20.25
        float2 clippingRange = (0.1, 1000)
        double3 xformOp:translate = (0, 1.4, 3)
        uniform token[] xformOpOrder = ["xformOp:translate"]
    }

    def DomeLight "DomeLight"
    {
        color3f inputs:color = (1, 1, 1)
        float inputs:intensity = 1.0
    }
}
