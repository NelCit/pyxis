#usda 1.0
(
    defaultPrim = "World"
    metersPerUnit = 1
    upAxis = "Y"
    doc = "Pyxis golden light_multi — Sphere lit by Distant + Dome + Rect at the same time. M7 / M8a — closesthit's per-light loop accumulates contributions across all three light types."
)
def Xform "World"
{
    def Sphere "Sphere"
    {
        double radius = 0.7
        color3f[] primvars:displayColor = [(0.85, 0.55, 0.15)]
        double3 xformOp:translate = (0, 1, 0)
        uniform token[] xformOpOrder = ["xformOp:translate"]
    }
    def DistantLight "Sun"
    {
        color3f inputs:color = (1, 0.9, 0.7)
        float inputs:intensity = 2.0
        float xformOp:rotateY = -45
        float xformOp:rotateX = -25
        uniform token[] xformOpOrder = ["xformOp:rotateY", "xformOp:rotateX"]
    }
    def DomeLight "Sky"
    {
        color3f inputs:color = (0.50, 0.65, 1.0)
        float inputs:intensity = 0.6
    }
    def RectLight "Fill"
    {
        color3f inputs:color = (1, 1, 1)
        float inputs:intensity = 30
        float inputs:width  = 1.5
        float inputs:height = 1.5
        double3 xformOp:translate = (1.8, 1.8, 0.5)
        float xformOp:rotateY = 90
        uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:rotateY"]
    }
    def Camera "Camera"
    {
        float focalLength = 35.0
        float horizontalAperture = 36.0
        float verticalAperture = 20.25
        float2 clippingRange = (0.1, 1000)
        double3 xformOp:translate = (0, 1.4, 3)
        uniform token[] xformOpOrder = ["xformOp:translate"]
    }
}
