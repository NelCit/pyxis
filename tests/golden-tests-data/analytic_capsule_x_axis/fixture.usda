#usda 1.0
(
    defaultPrim = "World"
    metersPerUnit = 1
    upAxis = "Y"
    doc = "Pyxis golden analytic_capsule_x_axis — UsdGeomCapsule axis=X. Pins AnalyticGeom::TessellateCapsule hemisphere caps + cylinder body for the off-Y axis branch."
)
def Xform "World"
{
    def Capsule "Subject"
    {
        double radius = 0.4
        double height = 1.2
        uniform token axis = "X"
        color3f[] primvars:displayColor = [(0.85, 0.50, 0.85)]
        double3 xformOp:translate = (0, 1, 0)
        uniform token[] xformOpOrder = ["xformOp:translate"]
    }
    def Camera "Camera"
    {
        float focalLength = 35.0
        float horizontalAperture = 36.0
        float verticalAperture = 20.25
        float2 clippingRange = (0.1, 1000)
        double3 xformOp:translate = (0, 1.5, 4)
        uniform token[] xformOpOrder = ["xformOp:translate"]
    }
    def DomeLight "DomeLight"
    {
        color3f inputs:color = (1, 1, 1)
        float inputs:intensity = 1.2
    }
}
