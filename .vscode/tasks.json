{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build:dev",
      "type": "shell",
      "command": "cmake",
      "args": ["--build", "--preset", "dev"],
      "group": { "kind": "build", "isDefault": true },
      "problemMatcher": ["$gcc"]
    },
    {
      "label": "configure:dev",
      "type": "shell",
      "command": "cmake",
      "args": ["--preset", "dev"],
      "problemMatcher": []
    },
    {
      "label": "test:dev",
      "type": "shell",
      "command": "ctest",
      "args": ["--preset", "dev", "--output-on-failure"],
      "group": { "kind": "test", "isDefault": true },
      "problemMatcher": []
    }
  ]
}
