# vcpkg
vcpkg_installed/
.vcpkg-root
vcpkg-bootstrap.log
vcpkg-init.log

# Generated NOTICE
NOTICE.generated

# Headless / viewer effective-config sidecars dropped wherever the
# user happened to invoke the binary. The intentional artifacts go
# under `build/` (covered above); the named .effective.json file lands
# in the cwd when --effective-config is set without an absolute path.
/*.effective.json

# Headless EXR output dropped in the repo root when --output is a bare
# filename. Bundled HDRIs (resources/) and test fixtures (tests/) keep
# their .exr files; only root-level dumps are ignored.
/*.exr

# IDE / editor
.vs/
.idea/

# VSCode: share the curated workspace files (launch/tasks/settings/extensions)
# so new contributors get F5-debug, build tasks, and the Test Explorer wired
# up out of the box. Personal overrides go in *.code-workspace or local
# user-scope settings, both of which stay ignored.
.vscode/*
!.vscode/launch.json
!.vscode/tasks.json
!.vscode/settings.json
!.vscode/extensions.json
*.code-workspace
*.user
*.suo
*.sln.docstates
*.swp
*.swo
*~

