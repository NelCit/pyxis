*.pyc

# Crash reports / minidumps
Crashes/

# Local user config
parameters.local.json

# M8 stress-test scenes — large external assets the user downloads + drops
# under resources/scenes/. Bundled smoke-test fixtures (default.usd /
# default_sky.exr) stay tracked; everything else under resources/scenes/
# is local-only.
#
# CONVENTION: resources/scenes/<scene-name>/ for any external scene the
# user wants the M8 framework to load. Add the directory name here OR
# rely on the size-bounded default rule below.
/resources/scenes/world_lobby/

# M10 — per-fixture rolling KPI history (plan §35 / §36.6). Each
# regression run appends one row to <fixture-dir>/kpis.csv; dev runs
# would otherwise pollute git status. CI's nightly job uploads its
# own copy as a pipeline artifact; long-term history persistence is
# the perf-dashboard's job, not the repo's.
tests/regression/**/kpis.csv

# OS detritus
Thumbs.db
.DS_Store
desktop.ini
